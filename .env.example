# Luce Task Management System - Environment Configuration
# Copy this file to .env and fill in your values

# ===================================
# CORE SYSTEM CONFIGURATION
# ===================================

# Database Configuration (Required)
DATABASE_URL=sqlite:luce.db
# For PostgreSQL: DATABASE_URL=postgresql://username:password@localhost/luce
# For MySQL: DATABASE_URL=mysql://username:password@localhost/luce

# API Server Configuration
LUCE_HOST=127.0.0.1
LUCE_PORT=3000
LUCE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===================================
# INTEGRATION CREDENTIALS (DEPRECATED)
# ===================================
# 
# IMPORTANT: Integration credentials are now managed through the database
# via the /api/v1/credentials endpoints. The environment variables below
# are NO LONGER USED and should be migrated to database credentials.
#
# To add credentials, use the API:
# POST /api/v1/credentials
# {
#   "integration_type": "GitHub",
#   "name": "My GitHub Account", 
#   "credentials": {
#     "type": "GitHub",
#     "access_token": "ghp_your_token_here",
#     "default_repo": "owner/repo",
#     "webhook_secret": "optional_secret"
#   }
# }
#
# Legacy environment variables (DEPRECATED - DO NOT USE):
# GITHUB_ACCESS_TOKEN=ghp_your_token_here
# GITHUB_DEFAULT_REPO=owner/repo  
# GITHUB_WEBHOOK_SECRET=your_webhook_secret
# GITHUB_WEBHOOK_URL=http://localhost:3000/api/v1/integrations/github/webhook
# 
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token
# SLACK_SIGNING_SECRET=your-signing-secret
# SLACK_DEFAULT_CHANNEL=#general
#
# LINEAR_API_KEY=lin_api_your_key_here
# LINEAR_TEAM_ID=your-team-id
# LINEAR_WEBHOOK_SECRET=your-webhook-secret

# ===================================
# CREDENTIAL MANAGEMENT
# ===================================
#
# Use the credential management API to securely store integration credentials:
#
# 1. List credentials: GET /api/v1/credentials
# 2. Create credential: POST /api/v1/credentials
# 3. Test integration: POST /api/v1/integrations/{type}/test
# 4. View integrations: GET /api/v1/integrations
#
# Benefits of database credentials:
# - Encrypted storage
# - Multiple credentials per integration
# - Usage tracking and audit trails
# - Activation/deactivation without data loss
# - No sensitive data in environment variables