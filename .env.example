# GitHub Integration Configuration
# Copy this file to .env and fill in your values

# Required: GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
GITHUB_ACCESS_TOKEN=ghp_your_token_here

# Required: Default repository (format: owner/repo)
GITHUB_DEFAULT_REPO=your-username/your-repo

# Optional: Webhook secret for GitHub webhooks
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: Webhook URL for GitHub to send events
GITHUB_WEBHOOK_URL=http://localhost:3000/api/v1/integrations/github/webhook

# Optional: API server configuration
LUCE_API_HOST=127.0.0.1
LUCE_API_PORT=3000

# Optional: Database configuration
LUCE_DATABASE_URL=sqlite:luce.db